# Optional: full API root including /api (overrides EXPO_PUBLIC_DOMAIN when set).
# Local backend (same machine as Metro): http://localhost:8080/api
# Android emulator → host machine: http://10.0.2.2:8080/api
# Physical device on LAN: http://192.168.x.x:8080/api
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Production: HTTPS API on your domain (no scheme — app prepends https://)
# EXPO_PUBLIC_DOMAIN=api.yourdomain.com
